// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Full search result (heavy — capped at 200 rows) ────────────────────────


model Search {
  id          String   @id @default(cuid())
  entityName  String
  entityType  String   // "company" | "individual"
  status      String   @default("complete")
  summary     String?  @db.Text
  riskOverall Int      @default(0)
  riskSocial  Int      @default(0)
  riskTech    Int      @default(0)
  riskReg     Int      @default(0)
  highCount   Int      @default(0)
  critCount   Int      @default(0)
  createdAt   DateTime @default(now())
  completedAt DateTime?

  // Entity profile (resolved)
  profileImage  String?
  profileBio    String?  @db.Text
  profileUrl    String?
  profileLocation String?

  findings    Finding[]
  @@index([entityName])
  @@index([createdAt])
}
// ─── Lightweight history entry (capped at 500 rows) ─────────────────────────

model SearchHistory {
  id             String   @id
  entityName     String
  entityType     String
  riskScore      Int
  dataPointCount Int
  adapterCount   Int
  createdAt      DateTime
  status         String   // "complete" | "error"

  search   Search @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("search_history")
}



model Finding {
  id         String   @id @default(cuid())
  searchId   String
  search     Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)

  title      String
  value      String   @db.Text
  sourceUrl  String?
  sourceName String?  // "Google Search", "GitHub", etc.
  category   String   // "social" | "technical" | "regulatory"
  riskLevel  String   @default("low")
  confidence String   @default("medium")
  status     String   @default("needs_review") // "needs_review" | "confirmed" | "false_positive"
  urlValid   Boolean  @default(true)
  timestamp  DateTime @default(now())

  @@index([searchId])
  @@index([riskLevel])
}
